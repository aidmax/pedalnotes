# AWS Configuration for S3 Deployment
# Copy this file to .env and fill in your actual values

# AWS Region where your S3 bucket is located
AWS_REGION=us-east-1

# Name of your S3 bucket for static website hosting
AWS_BUCKET=your-workout-tracker-bucket

# AWS Access Key ID with S3 permissions
AWS_ACCESS_KEY_ID=your-access-key-id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: CloudFront Distribution ID for cache invalidation
# AWS_CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id

# Optional: Custom domain for your application
# CUSTOM_DOMAIN=yourdomain.com
